# Build artifacts
*.o
*.d
*.i
*.elf
*.gba
*.bin
*.lz
*.map
stage1.o

# Compiler-generated .s intermediates: Make's %.o:%.c rule writes a .s next to
# every src/ .c, so refresh_expected.sh / a full `make` litters src/ with them.
# Ignore all .s under src/ EXCEPT the hand-written glue (crt0/exports/imports),
# which have no .c sibling and are tracked source-of-truth.
src/**/*.s
!src/**/crt0.s
!src/**/exports.s
!src/**/imports.s

# The cross-dir rule (asm/%.o: src/%.c) regenerates asm/<bank>/X.s for every
# matched src/<bank>/X.c — build artifacts, not source-of-truth. Ignoring them
# does NOT untrack the committed raw disassembly .s (those stay tracked since
# git never untracks tracked files). NOTE: a genuinely new raw-disassembly .s
# (e.g. a fresh split) must be added with `git add -f`.
asm/**/*.s

# Per-machine expected disassembly cache
expected/

# decomp-permuter scratch (regenerated by import.py) + --debug artifacts
nonmatchings/
debug_source.c
debug_compiled_object.o

# User-installed toolchains (per INSTALL.md, installed via external git clone)
tools/gcc296/
tools/agbcc/
tools/gcc3/
tools/asm-differ/

# Python
__pycache__/
*.pyc

# Editor / OS
.vscode/
.idea/
*.swp
.DS_Store
*:Zone.Identifier
*.bak

# Dialog data extracted from baserom.gba by tools/unpack_strings + pack_strings (regenerated by make)
data/strings/

# m4a/Sappy
lib/m4a/m4a.s
